<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Add Product</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
    rel="stylesheet"
  >
</head>
<body class="bg-light">

  <div class="container mt-5">
    <div class="row justify-content-center">
      <div class="col-md-6">

        <div class="card shadow-sm">
          <div class="card-header bg-primary text-white text-center">
            <h4>Add New Product</h4>
          </div>

          <div class="card-body">
            <form id="productForm" novalidate>

              
              <div class="mb-3">
                <label class="form-label fw-bold">Product Name <span class="text-danger">*</span></label>
                <input
                  type="text"
                  name="productName"
                  class="form-control"
                  placeholder="e.g., Laptop, Smartphone"
                  required
                >
              </div>

              <div class="mb-3">
                <label class="form-label fw-bold">Product Price <span class="text-danger">*</span></label>
                <div class="input-group">
                  <span class="input-group-text">$</span>
                  <input
                    type="number"
                    step="0.01"
                    name="productPrice"
                    class="form-control"
                    placeholder="0.00"
                    required
                  >
                </div>
              </div>

            
              <div class="mb-3">
                <label class="form-label fw-bold">Product Quantity <span class="text-danger">*</span></label>
                <input
                  type="number"
                  min="1"
                  name="productQuantity"
                  class="form-control"
                  placeholder="Enter stock quantity"
                  required
                >
              </div>

              <div class="mb-3">
                <label class="form-label fw-bold">Product Image URL <span class="text-danger">*</span></label>
                <input
                  type="text"
                  name="productImage"
                  class="form-control"
                  placeholder="Enter image URL"
                  required
                >
              </div>

              
              <div class="mb-4">
                <label class="form-label fw-bold">Product Description <span class="text-danger">*</span></label>
                <textarea
                  name="prodDescription"
                  class="form-control"
                  rows="4"
                  placeholder="Describe your product features, specifications, etc."
                  required
                ></textarea>
              </div>

             
              <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success btn-lg flex-grow-1" id="submitBtn">
                  <i class="bi bi-plus-circle"></i> Add Product
                </button>
                <a href="/index" class="btn btn-secondary btn-lg">
                  Cancel
                </a>
              </div>

              <div id="message" class="mt-3"></div>

            </form>
          </div>
        </div>

      </div>
    </div>
  </div>


  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  
  <script>
    document.getElementById('productForm').addEventListener('submit', async function(e) {
      e.preventDefault();
      
      const formData = {
        productName: document.querySelector('input[name="productName"]').value,
        productPrice: document.querySelector('input[name="productPrice"]').value,
        productQuantity: document.querySelector('input[name="productQuantity"]').value,
        productImage: document.querySelector('input[name="productImage"]').value
      };

      const token = localStorage.getItem('token');
      
      if (!token) {
        document.getElementById('message').innerHTML = '<div class="alert alert-danger">Please login first</div>';
        return;
      }

      try {
        const response = await fetch('/api/v1/addProduct', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${token}`
          },
          body: JSON.stringify(formData)
        });

        const result = await response.json();

        if (response.ok) {
          document.getElementById('message').innerHTML = '<div class="alert alert-success">Product added successfully!</div>';
          setTimeout(() => {
            window.location.href = '/index';
          }, 1500);
        } else {
          document.getElementById('message').innerHTML = '<div class="alert alert-danger">' + (result.message || 'Error adding product') + '</div>';
        }
      } catch (error) {
        document.getElementById('message').innerHTML = '<div class="alert alert-danger">Error: ' + error.message + '</div>';
      }
    });
  </script>
</body>
</html>
